  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 916d0fa205b19e94e8c2acf7f2fb3530, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 24763580416
    m_Localized: 'Aim with the mouse and shoot with left click.

      Dash with
      the space key.'
    m_Metadata:
      m_Items: []
  - m_Id: 955857125376
    m_Localized: 'Switch weapon with Q and E.

      Recover health absorbing water.'
    m_Metadata:
      m_Items: []
  - m_Id: 89361855201280
    m_Localized: Upon touching the root, your entire mind goes blank.
    m_Metadata:
      m_Items: []
  - m_Id: 744053375418368
    m_Localized: Your eyes cannot see and your ears cannot hear; all you feel is
      your body breaking and stretching into infinite shapes, as if a thousand hands
      were trying to tear a piece of you away.
    m_Metadata:
      m_Items: []
  - m_Id: 746143048974336
    m_Localized: Each cell of your being branches into hundreds of appendages, and
      these in turn branch into hundreds more successively.
    m_Metadata:
      m_Items: []
  - m_Id: 746145766883328
    m_Localized: Your entire body gently covers the planet, embracing it like a teddy
      bear. And then you feel it; you are able to perceive every event on this celestial
      body.
    m_Metadata:
      m_Items: []
  - m_Id: 758333424451584
    m_Localized: Upon touching the root, your entire mind goes blank.
    m_Metadata:
      m_Items: []
  - m_Id: 758332619145216
    m_Localized: The fight continues until you take advantage of a moment of inattention
      from your opponent to knock him down. Lying on the ground, you deliver blow
      after blow to his face until he stops moving. Seeing what you have just done,
      you awaken.
    m_Metadata:
      m_Items: []
  - m_Id: 758331276967936
    m_Localized: You find yourself transported to a fierce battle. Before you, a
      grotesque creature hurls blows relentlessly. You respond by dodging and returning
      each attack.
    m_Metadata:
      m_Items: []
  - m_Id: 758328928157696
    m_Localized: Upon touching the root, your entire mind goes blank.
    m_Metadata:
      m_Items: []
  - m_Id: 752951922704384
    m_Localized: You don't know why, but somehow you know that the one walking is
      you. It doesn't feel like a dream, but something far more real.
    m_Metadata:
      m_Items: []
  - m_Id: 752876832079872
    m_Localized: Upon touching the root, your entire mind goes blank.
    m_Metadata:
      m_Items: []
  - m_Id: 765545882501120
    m_Localized: You lift something with your arm and bring it down upon the defenseless
      creature. A dull crunch is all you hear before returning to reality.
    m_Metadata:
      m_Items: []
  - m_Id: 765538466971648
    m_Localized: We have to do it; there's no other choice.
    m_Metadata:
      m_Items: []
  - m_Id: 765536218824704
    m_Localized: You freeze, unsure what to do, until a voice beside you speaks.
    m_Metadata:
      m_Items: []
  - m_Id: 765493042659328
    m_Localized: You find yourself in a dark room. Before you stands a small, trembling
      figure, afraid of you.
    m_Metadata:
      m_Items: []
  - m_Id: 752912127148032
    m_Localized: Little by little, a straight, paved street appears before you, surrounded
      by buildings that seem to disappear into the clouds. You begin to walk, though
      you don't want to; no matter how hard you try, your body moves on its own.
    m_Metadata:
      m_Items: []
  - m_Id: 4174054573654016
    m_Localized: Suddenly, a glow covers the sky, and you can't help but close your
      eyes. As you squeeze them shut, a constant buzzing fills your ears, and you
      catch muffled screams before it all ends.
    m_Metadata:
      m_Items: []
  - m_Id: 4174427115929600
    m_Localized: The sea of sensations overwhelms your mind, but before you awaken
      from this reverie, an idea clarifies in your thoughts.
    m_Metadata:
      m_Items: []
  - m_Id: 4174439296188416
    m_Localized: You are the great tree.
    m_Metadata:
      m_Items: []
  - m_Id: 4349827366666240
    m_Localized: Path through the Emerald Forest. Proceed with caution.
    m_Metadata:
      m_Items: []
  - m_Id: 4350188731121664
    m_Localized: To the cave.
    m_Metadata:
      m_Items: []
  - m_Id: 4350996629569536
    m_Localized: Exit from the forest to the east.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
