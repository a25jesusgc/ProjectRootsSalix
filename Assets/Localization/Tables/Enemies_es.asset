  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Enemies_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: 3f63dd2e5b3a9b64d93105ba50b014b3, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 83978764288
    m_Localized: Parece que la sustancia viscosa de su cuerpo es muy sensible a altas
      temperaturas.
    m_Metadata:
      m_Items: []
  - m_Id: 73614639104
    m_Localized: "Cuando ocurri\xF3 el cataclismo, los animales conocidos como gatos
      se convirtieron en estas criaturas viscosas y semil\xEDquidas. De car\xE1cter
      curioso, todav\xEDa mantienen la costumbre de frotarse en se\xF1al de afecto.
      Sin embargo, debido a su nueva fisiolog\xEDa \xE1cida el contacto con ellos
      ocasiona graves da\xF1os, por lo que conviene evitarlos."
    m_Metadata:
      m_Items: []
  - m_Id: 6346391552
    m_Localized: Gatolimo
    m_Metadata:
      m_Items: []
  - m_Id: 1260002885632
    m_Localized: "Sus habilidades de hombre lobo los hacen m\xE1s resistentes bajo
      la luz de la luna."
    m_Metadata:
      m_Items: []
  - m_Id: 1257989619712
    m_Localized: Un miembro de los bandidos del bosque. Todos ellos fueron afectados
      por mutaciones que los volvieron hombres lobo.
    m_Metadata:
      m_Items: []
  - m_Id: 1255779221504
    m_Localized: Bandido Lupino (Garras)
    m_Metadata:
      m_Items: []
  - m_Id: 1209830621184
    m_Localized: "Por su anatom\xEDa, constre\xF1ir su cuerpo con el lazo de espinas
      parece herirle bastante."
    m_Metadata:
      m_Items: []
  - m_Id: 1207590862848
    m_Localized: "Un an\xE9lido volador que se alimenta de la sangre de otros seres
      vivos. Cuando tiene hambre, puede abalanz\xE1rse r\xE1pidamente a morder a
      su objetivo."
    m_Metadata:
      m_Items: []
  - m_Id: 1205179138048
    m_Localized: Sanguivuela
    m_Metadata:
      m_Items: []
  - m_Id: 1317678759936
    m_Localized: Bandido Lupino (Tirador)
    m_Metadata:
      m_Items: []
  - m_Id: 1319754940416
    m_Localized: "Algunos de los bandidos del bosque no poseen garras tan poderosas,
      pero lo compensan con la habilidad de disparar dientes abriendo su cr\xE1neo."
    m_Metadata:
      m_Items: []
  - m_Id: 1321327804416
    m_Localized: "Durante la noche, sus disparos son m\xE1s mort\xEDferos."
    m_Metadata:
      m_Items: []
  - m_Id: 1385718759424
    m_Localized: Lobira
    m_Metadata:
      m_Items: []
  - m_Id: 1387228708864
    m_Localized: "La l\xEDder de los bandidos del bosque. Su personalidad feroz y
      su gran fuerza le ha permitido mantenerse como la jefa, enfrent\xE1ndose contra
      todos aquellos que intenten doblegarla."
    m_Metadata:
      m_Items: []
  - m_Id: 1388658966528
    m_Localized: '-'
    m_Metadata:
      m_Items: []
  - m_Id: 1437086400512
    m_Localized: Yogui
    m_Metadata:
      m_Items: []
  - m_Id: 1438520852480
    m_Localized: "Un antiguo le\xF1ador que habita el bosque desde hace mucho tiempo.
      Alberga un gran rencor hacia las ra\xEDces del gran \xE1rbol."
    m_Metadata:
      m_Items: []
  - m_Id: 1439896584192
    m_Localized: '-'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
